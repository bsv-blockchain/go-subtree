# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-subtree
# Load Order: 90 (loaded after all defaults, overrides earlier files)
#
# This file contains project-specific configuration that overrides the defaults
# from earlier env files. Use this for settings unique to this repository.
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION
# ================================================================================================

# Coverage Provider Selection (override from internal to codecov)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusions (matches codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=test/,vendor/,testdata/,examples/,example/,plans/,docs/,.github/,.mage-cache/,.vscode/,bin/,mocks/,testing/

# Skip URL Checks in Coverage Reports
GO_COVERAGE_SKIP_URL_CHECKS=true

# ================================================================================================
# 🏗️ BUILD TAG CONFIGURATION
# ================================================================================================

# Exclude GOOS names from auto-discovered build tags to prevent conflicts in Go 1.26+.
# Using GOOS names (e.g. "windows") as custom build tags causes internal/goos redeclarations
# when running on a different OS (e.g. macOS with -tags windows).
MAGE_X_AUTO_DISCOVER_BUILD_TAGS_EXCLUDE=race,custom,windows
